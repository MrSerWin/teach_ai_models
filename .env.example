# Copy to .env and fill in.
WIN_HOST=192.168.1.100
WIN_USER=trainer
WIN_SSH_PORT=22

# Remote paths (inside WSL2). /mnt/d/ maps to Windows D: drive.
REMOTE_RUNS_DIR=/mnt/d/runs
REMOTE_DATASETS_DIR=/mnt/d/datasets

# Base conda env on the remote. Cloned per-experiment so the base stays clean.
BASE_CONDA_ENV=ml_base

# Local paths
LOCAL_MODELS_DIR=./models

# --- Notifications (optional) ---
# NOTIFY_MACOS=1          # auto-enabled on macOS; set 0 to disable
# NTFY_TOPIC=my-training  # push to https://ntfy.sh/<topic> — install the ntfy app on your phone
# NTFY_SERVER=https://ntfy.sh  # override for a self-hosted ntfy instance
